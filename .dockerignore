# =============================================================================
# DeepAgentForce .dockerignore
# 构建时不复制到镜像的文件
# =============================================================================

# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker 相关（防止循环构建）
Dockerfile
docker-compose.yml
.dockerignore

# 文档
*.md
!README.md
docs/

# 测试
tests/
*.test.py

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Electron
electron/node_modules/
electron/dist/
electron/build/

# 日志
*.log
logs/

# 其他
*.bak
*.tmp
/.vscode/

# =============================================================================
# 运行时数据目录（通过 docker-compose volume 挂载，不打入镜像）
# =============================================================================
# macOS 隐藏文件
data/.DS_Store
data/.milvus.db.lock
# 用户上传的文档
data/uploads/
# 会话历史记录
data/history/
# AI 生成的文件
data/outputs/
# RAG 向量索引数据库
data/rag_storage/
data/milvus.db
# 用户配置（每个租户独立）
data/saved_config.json
data/saved_config_*.json
# 用户画像
data/person_like.json
data/person_like_*.json
# 工具脚本（不属于主应用）
data/claw.py
